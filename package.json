{
	"name": "le-todo-truc",
	"module": "index.ts",
	"type": "module",
	"scripts": {
		"test": "bun test",
		"build:css": "bun build src/assets/main.css --outdir ./dist/assets --minify",
		"build:js": "bun build src/assets/main.ts --outdir ./dist/assets --define process.env.DEV_MODE=false --minify",
		"build:js:dev": "bun build src/assets/main.ts --outdir ./dist/assets --define process.env.DEV_MODE=true --sourcemap=external",
		"build:html": "bun src/bundle.ts",
		"build": "bun run build:css && bun run build:js && bun run build:html",
		"build:dev": "bun run build:css && bun run build:js:dev && bun run build:html",
		"serve": "bun src/serve.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@happy-dom/global-registrator": "^20.8.9",
		"@types/bun": "^1.3.12"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@zeix/le-truc": "^2.0.0-next.3"
	}
}
